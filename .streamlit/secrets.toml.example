# Rename this file's CONTENT (not the file itself) into:
# Streamlit Cloud dashboard -> Your app -> Settings -> Secrets
# Paste the block below there (do not commit real secrets.toml to GitHub).

QX_EMAIL = "your_email@example.com"
QX_PASSWORD = "your_password"
QX_COOKIES = "your_quotex_cookie_string"
QX_TOKEN = "your_quotex_token"
