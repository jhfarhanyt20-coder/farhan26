# Copy this file to .env for LOCAL runs only.
# On Streamlit Cloud, DO NOT use this file — set the same keys
# in App settings -> Secrets instead (see .streamlit/secrets.toml.example).

QX_EMAIL=your_email@example.com
QX_PASSWORD=your_password
QX_COOKIES=your_quotex_cookie_string
QX_TOKEN=your_quotex_token
